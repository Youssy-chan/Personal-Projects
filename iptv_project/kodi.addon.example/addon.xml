<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="kodi.addon.example" name="Live TV &amp; Sports" version="1.0.0" provider-name="Developer">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Live TV &amp; Sports Streams</summary>
        <description lang="en">A client addon that connects to the local IPTV backend scraper to watch live streams.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
