<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane fx:controller="it.unimore.rubrica.controller.AddContactController"
          hgap="8" vgap="8"
          xmlns="http://javafx.com/javafx/21"
          xmlns:fx="http://javafx.com/fxml/1"
          styleClass="@/app.css">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <columnConstraints>
        <ColumnConstraints halignment="RIGHT" minWidth="90"/>
        <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
    </columnConstraints>

    <!-- Nome -->
    <Label text="Nome" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="nameField" promptText="Mario Rossi"
               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <!-- Telefono -->
    <Label text="Telefono" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="phoneField" promptText="3331234567"
               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <!-- Email -->
    <Label text="Email" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="emailField" promptText="mario@example.com"
               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <!-- Pulsanti -->
    <HBox spacing="8" alignment="CENTER_RIGHT"
          GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="2">
        <Button text="Annulla" onAction="#onCancel"/>
        <Button text="Crea" defaultButton="true" onAction="#onCreate"/>
    </HBox>
</GridPane>
